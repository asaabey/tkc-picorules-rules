#define_ruleblock([[rb_id]], {
    description: "Assess CVD risk based on AusCVDRisk General Equation (WIP)",
    is_active:2,
});

#doc(, { txt:"work in progress" });

/* Reference Specification: AusCVDRisk calculator - Technical specifications_20240926.pdf */

#doc(,{ section:"Gather precursor variables" });

tkc_cat => rout_at_risk.tkc_cat._.bind();

has_high_risk_factors => rout_cvra_aus_cvd_risk_pre.has_high_risk_factors._.bind();
has_mandatory_vars_for_general_equation => rout_cvra_aus_cvd_risk_pre.has_mandatory_vars_for_general_equation._.bind();
vars_are_in_range_for_general_equation => rout_cvra_aus_cvd_risk_pre.vars_are_in_range_for_general_equation._.bind();

sex => rout_cvra_aus_cvd_risk_pre.sex._.bind();
age => rout_cvra_aus_cvd_risk_pre.age._.bind();
nzdep_quintile => rout_cvra_aus_cvd_risk_pre.nzdep_quintile._.bind();
is_smoker => rout_cvra_aus_cvd_risk_pre.is_smoker._.bind();
is_exsmoker => rout_cvra_aus_cvd_risk_pre.is_exsmoker._.bind();
is_nonsmoker => rout_cvra_aus_cvd_risk_pre.is_nonsmoker._.bind();
has_hist_of_af => rout_cvra_aus_cvd_risk_pre.has_hist_of_af._.bind();
has_dm => rout_cvra_aus_cvd_risk_pre.has_dm._.bind();
sbp_val => rout_cvra_aus_cvd_risk_pre.sbp_val._.bind();
hdl_ratio => rout_cvra_aus_cvd_risk_pre.hdl_ratio._.bind();
is_on_bplm => rout_cvra_aus_cvd_risk_pre.is_on_bplm._.bind();
is_on_llm => rout_cvra_aus_cvd_risk_pre.is_on_llm._.bind();
is_on_atm => rout_cvra_aus_cvd_risk_pre.is_on_atm._.bind();

recalibration_factor => rout_cvra_aus_cvd_risk_pre.recalibration_factor._.bind();

/*
eq 1: Male General Equation
eq 2: Female General Equation
eq 3: Male Diabetes Equation
eq 4: Female Diabetes Equation
*/
eq :
    {has_mandatory_vars_for_general_equation = 0 or vars_are_in_range_for_general_equation = 0 or has_high_risk_factors = 1 => null },
    {sex = 1 => 1},
    {sex = 0 => 2};

age_product :
    {eq = 1 => (age - 53.77579) * 0.0691512},
    {eq = 2 => (age - 58.47472) * 0.0905192};

seifa_product :
    {eq = 1 => (nzdep_quintile - 2.628206) * 0.0900502},
    {eq = 2 => (nzdep_quintile - 2.625575) * 0.0978413};

smoker_product :
    {eq = 1 => (is_smoker) * 0.5782258},
    {eq = 2 => (is_smoker) * 0.8235061};

exsmoker_product :
    {eq = 1 => (is_exsmoker) * 0.0635803},
    {eq = 2 => (is_exsmoker) * 0.1162342};

nonsmoker_product :
    {eq = 1 => (is_nonsmoker) * 0},
    {eq = 2 => (is_nonsmoker) * 0};

af_product :
    {eq = 1 => (has_hist_of_af) * 0.474629},
    {eq = 2 => (has_hist_of_af) * 0.709571};

diabetes_product :
    {eq = 1 => (has_dm) * 0.5829839},
    {eq = 2 => (has_dm) * 0.6207569};

/*
The constants used in bmi_product for the General Equation are defined slightly ambiguously in the spec.
The rounded version (eg Women: 27.5, Men: 27.8) is provided in Table 4: Beta coefficients in the Aus CVD Risk Calculator general population equation by
sex but:
- in that table, BMI has a footnote indicating usaage of the unrounded values (Women: 27.47728, Men: 27.84061) 
- the unrounded constants are used in Table 5: Aus CVD Risk Calculator general equation.
- the unrounded constants are used in the two test cases for the general calculator.
- the online calculator uses the rounded constants.
- We have been recommended by Lisa Kalman of The Heart Foundation to follow the specification rather than the online calculator
  - this has the small chance of presenting a result which differs from the calculator.
*/

/* Option 1: Align with the online calculator and use the incorrect constants: bmi_product will evaluate to a tiny tiny fraction */
/*
bmi_product :
    {eq = 1 => (27.8406 - 27.8) * 0.0124319},
    {eq = 2 => (27.47728 - 27.5) * 0.0057835};
*/

/* Option 2: Align with the spec and use the correct constants: bmi_product will evaluate to 0 */
bmi_product :
    {eq = 1 => (27.8406 - 27.8406) * 0.0124319},
    {eq = 2 => (27.47728 - 27.47728) * 0.0057835};


sbp_product :
    {eq = 1 => (sbp_val - 129.1706) * 0.0139242},
    {eq = 2 => (sbp_val - 129.2052) * 0.0114172};

hdl_ratio_product :
    {eq = 1 => (hdl_ratio - 4.325589) * 0.1350063},
    {eq = 2 => (hdl_ratio - 3.641988) * 0.1067098};

obplm_product :
    {eq = 1 => (is_on_bplm) * 0.2676661},
    {eq = 2 => (is_on_bplm) * 0.3092255};

ollm_product :
    {eq = 1 => (is_on_llm) * -0.0383788},
    {eq = 2 => (is_on_llm) * -0.0863215};

oatm_product :
    {eq = 1 => (is_on_atm) * 0.0981934},
    {eq = 2 => (is_on_atm) * 0.1622663};

obplm_sbp_product :
    {eq = 1 => (sbp_val - 129.1706) * (is_on_bplm) * -0.0054419},
    {eq = 2 => (sbp_val - 129.2052) * (is_on_bplm) * -0.0066143};

age_diabetes_product :
    {eq = 1 => (age - 53.77579) * (has_dm) * -0.018881},
    {eq = 2 => (age - 58.47472) * (has_dm) * -0.0230893};

age_sbp_product :
    {eq = 1 => (age - 53.77579) * (sbp_val - 129.1706) * -0.0001952},
    {eq = 2 => (age - 58.47472) * (sbp_val - 129.2052) * -0.0002353};

sum_product : { eq!? => 0
    + age_product
    + seifa_product
    + smoker_product
    + exsmoker_product
    + nonsmoker_product
    + af_product
    + diabetes_product
    + bmi_product
    + sbp_product
    + hdl_ratio_product
    + obplm_product
    + ollm_product
    + oatm_product
    + obplm_sbp_product
    + age_diabetes_product
    + age_sbp_product
};

bsf :
    {eq = 1 => 0.9728782},
    {eq = 2 => 0.9828361};

raw_risk_percent :
    {. => (1 - power(bsf, exp(sum_product))) * 100};

recalibrated_risk_percent :
    {raw_risk_percent < 1 => 1},
    { => raw_risk_percent * recalibration_factor};

rounded_risk_percent :
    { . => round(recalibrated_risk_percent, 0)};

risk_cat :
    {has_high_risk_factors = 1                               => 3}, /* High risk from override conditions */
    {rounded_risk_percent >= 0 and rounded_risk_percent < 5  => 1}, /* Low risk */
    {rounded_risk_percent >= 5 and rounded_risk_percent < 10 => 2}, /* Intermediate risk */
    {rounded_risk_percent >= 10                              => 3}; /* High risk */

[[rb_id]] : { risk_cat!? => 1},{ => 0};